# The API URL of your Supabase project instance
NEXT_PUBLIC_SUPABASE_URL=

# The public anonymous API key used for safe client-side access to Supabase.
# WARNING: Do not share or commit production keys to public repositories!
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# The secret service role API key used strictly for server-side administrative tasks.
# WARNING: NEVER expose this key to the client-side as it bypasses all Row Level Security (RLS) policies!
SUPABASE_SERVICE_ROLE_KEY=
